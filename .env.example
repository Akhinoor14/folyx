# ============================================
# FOLYX — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- GitHub ---
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_ORG=your-github-username
GITHUB_TEMPLATE_REPO=folyx-portfolio-template

# --- Cloudflare R2 (for PDFs, GLB files) ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=folyx-assets
R2_PUBLIC_URL=https://assets.folyx.com

# --- Vercel API (for auto-subdomain on Add Client) ---
VERCEL_API_TOKEN=your-vercel-token
VERCEL_PROJECT_ID=your-project-id
VERCEL_TEAM_ID=your-team-id

# --- EmailJS (client-side safe) ---
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your-public-key

# --- Admin Auth ---
ADMIN_SECRET_KEY=your-super-secret-admin-key-min-32-chars

# --- App Config ---
NEXT_PUBLIC_APP_NAME=Folyx
NEXT_PUBLIC_APP_DOMAIN=folyx.com
NEXT_PUBLIC_APP_URL=https://folyx.com
